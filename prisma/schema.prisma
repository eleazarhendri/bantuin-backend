// Prisma Schema — Bantuin Backend
// Database: SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enum ────────────────────────────────────────────────────────────────────
// SQLite tidak support native enum — disimulasikan dengan String + validasi di app layer

// ─── User ────────────────────────────────────────────────────────────────────
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String?
  name      String?
  /// URL foto profil dari Google atau upload manual
  photoUrl  String?
  /// Role: "USER" | "MITRA" | "ADMIN"
  role      String   @default("USER")
  googleId  String?  @unique
  /// true setelah admin menyetujui pendaftaran mitra
  isMitra   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relasi
  mitraProfile        MitraProfile?
  mitraRegistrations  MitraRegistration[]
  ordersAsUser        Order[]             @relation("UserOrders")
  ordersAsMitra       Order[]             @relation("MitraOrders")
  wallet              Wallet?
  conversationsAsUser  ChatConversation[]  @relation("UserConversations")
  conversationsAsMitra ChatConversation[]  @relation("MitraConversations")
  sentMessages         ChatMessage[]       @relation("SentMessages")
  notifications        Notification[]
  reviewsGiven         Review[]            @relation("ReviewsByUser")
  reviewsReceived      Review[]            @relation("ReviewsForMitra")

  @@map("users")
}

// ─── MitraProfile ─────────────────────────────────────────────────────────────
// Data profil mitra yang aktif (sudah APPROVED)
model MitraProfile {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneNumber String   @default("")
  campus      String   @default("")
  domicile    String   @default("")

  /// Kategori utama (dari registrasi). Bisa berisi beberapa kategori dipisah koma.
  /// Contoh: "jastip,beberes"
  category    String   @default("")

  description String   @default("")
  price       Float    @default(0)
  ktmPath     String?
  selfiePath  String?
  isVerified  Boolean  @default(false)

  /// Rating rata-rata (0.0 – 5.0)
  rating      Float    @default(0)
  /// Jumlah ulasan
  totalReviews Int     @default(0)
  /// Jumlah transaksi selesai
  totalOrders  Int     @default(0)

  /// Status online mitra (diupdate oleh mitra sendiri)
  isOnline    Boolean  @default(false)

  /// Bio singkat mitra
  bio         String   @default("")

  /// Koordinat lokasi mitra (opsional — diisi mitra sendiri)
  latitude    Float?
  longitude   Float?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("mitra_profiles")
}

// ─── MitraRegistration ────────────────────────────────────────────────────────
// Tabel pendaftaran mitra — setiap submission user disimpan di sini.
// Status: "PENDING" | "APPROVED" | "REJECTED"
model MitraRegistration {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Data identitas
  nik             String
  ktpUrl          String
  selfieUrl       String

  // Data layanan
  serviceCategory String
  experience      String

  /// Koordinat lokasi toko/area layanan (diisi saat pendaftaran, opsional)
  latitude        Float?
  longitude       Float?

  /// Status review admin: "PENDING" | "APPROVED" | "REJECTED"
  status          String   @default("PENDING")

  /// Catatan dari admin saat reject (opsional)
  adminNote       String?

  /// ID admin yang melakukan review (nullable — belum direview)
  reviewedBy      Int?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("mitra_registrations")
}

// ─── Order ────────────────────────────────────────────────────────────────────
// Tabel pesanan — dibuat oleh user, dikerjakan oleh mitra
// Status: "pending" | "accepted" | "shopping" | "on_the_way" | "diagnosis" |
//         "in_progress" | "ready_pickup" | "done" | "cancelled" | "payment_failed"
model Order {
  id              Int      @id @default(autoincrement())

  // Relasi user & mitra
  userId          Int
  user            User     @relation("UserOrders", fields: [userId], references: [id], onDelete: Cascade)
  mitraId         Int
  mitra           User     @relation("MitraOrders", fields: [mitraId], references: [id], onDelete: Cascade)

  // Kategori layanan
  categoryId      String
  categoryName    String

  // Detail pesanan
  itemDescription String
  storeName       String?
  notes           String?
  photoUrl        String?

  // Harga
  itemBudget      Float    @default(0)
  serviceFee      Float    @default(0)
  platformFee     Float    @default(0)
  totalAmount     Float    @default(0)

  /// Status pesanan
  status          String   @default("pending")

  // Timestamps status
  acceptedAt      DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?

  /// Pembatalan setelah accepted: user request → mitra approve/reject dalam 5 menit
  /// Status: null | "requested" | "approved" | "rejected"
  cancellationStatus    String?
  cancellationReason    String?
  cancellationRequestedAt DateTime?

  /// Apakah user sudah memberi ulasan
  isReviewed      Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  conversation    ChatConversation?
  review          Review?

  @@map("orders")
}

// ─── Wallet ───────────────────────────────────────────────────────────────────
// Saldo dompet mitra — satu wallet per mitra
model Wallet {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions WalletTransaction[]

  @@map("wallets")
}

// ─── WalletTransaction ────────────────────────────────────────────────────────
// Riwayat transaksi wallet mitra
// Type: "CREDIT" (masuk) | "DEBIT" (keluar/withdraw)
model WalletTransaction {
  id          Int      @id @default(autoincrement())
  walletId    Int
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount      Float
  /// "CREDIT" | "DEBIT"
  type        String
  description String
  orderId     Int?
  createdAt   DateTime @default(now())

  @@map("wallet_transactions")
}

// ─── ChatConversation ─────────────────────────────────────────────────────────
// Satu conversation per pasangan user-mitra (atau per order)
model ChatConversation {
  id            Int      @id @default(autoincrement())
  /// ID user (pembeli)
  userId        Int
  user          User     @relation("UserConversations", fields: [userId], references: [id], onDelete: Cascade)
  /// ID mitra (penjual)
  mitraId       Int
  mitra         User     @relation("MitraConversations", fields: [mitraId], references: [id], onDelete: Cascade)
  /// Opsional: terhubung ke order tertentu
  orderId       Int?     @unique
  order         Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  /// Nama kategori layanan
  categoryName  String   @default("")
  /// Pesan terakhir (untuk preview di list)
  lastMessage   String   @default("")
  lastMessageAt DateTime @default(now())
  /// Jumlah pesan belum dibaca oleh user
  unreadByUser  Int      @default(0)
  /// Jumlah pesan belum dibaca oleh mitra
  unreadByMitra Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages ChatMessage[]

  @@unique([userId, mitraId, orderId])
  @@map("chat_conversations")
}

// ─── ChatMessage ──────────────────────────────────────────────────────────────
// Pesan individual dalam sebuah conversation
model ChatMessage {
  id             Int              @id @default(autoincrement())
  conversationId Int
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       Int
  sender         User             @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  /// "text" | "image" | "system"
  type           String           @default("text")
  content        String
  imageUrl       String?
  isRead         Boolean          @default(false)
  createdAt      DateTime         @default(now())

  @@map("chat_messages")
}

// ─── Notification ─────────────────────────────────────────────────────────────
// Notifikasi untuk user dan mitra
// Type: "order" | "chat" | "balance" | "system" | "promo"
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// "order" | "chat" | "balance" | "system" | "promo"
  type      String
  title     String
  body      String
  /// Data tambahan (JSON string) — misal orderId, conversationId
  data      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

// ─── Review ───────────────────────────────────────────────────────────────────
// Ulasan user untuk mitra setelah pesanan selesai
model Review {
  id        Int      @id @default(autoincrement())
  orderId   Int      @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation("ReviewsByUser", fields: [userId], references: [id], onDelete: Cascade)
  mitraId   Int
  mitra     User     @relation("ReviewsForMitra", fields: [mitraId], references: [id], onDelete: Cascade)
  /// Rating 1–5
  rating    Float
  comment   String
  createdAt DateTime @default(now())

  @@map("reviews")
}
